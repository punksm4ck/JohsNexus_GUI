function saveJobNote(id, val) {
  jobNotes[id] = val;
  persistNotes();
}

function toggleSave(id) {
  const job = allJobs.find(j=>j.id===id) || savedJobs.find(j=>j.id===id);
  const idx = savedJobs.findIndex(s=>s.id===id);
  if (idx>-1) { savedJobs.splice(idx,1); showToast('Removed from saved jobs.', 2000); }
  else if (job) { savedJobs.push(job); showToast('Job saved! ♥', 2000, 'success'); }
  persistSaved();
  updateSavedCount();
  renderJobList();
  if (selectedJob && selectedJob.id===id) renderDetailPanel(selectedJob);
}

function updateSavedCount() {
  const n = savedJobs.length;
  document.getElementById('saved-count').textContent = `(${n})`;
  const mel = document.getElementById('m-saved');
  if (mel) mel.textContent = n;
  persistMetric('saved', n);
}

function addToTracker(id, stage) {
  if (!stage) return;
  const job = allJobs.find(j=>j.id===id) || savedJobs.find(j=>j.id===id);
  if (!job) return;
  Object.keys(trackerApps).forEach(s => {
    trackerApps[s] = (trackerApps[s]||[]).filter(a=>a.id!==id);
  });
  if (!trackerApps[stage]) trackerApps[stage] = [];
  trackerApps[stage].push({...job, trackedAt:new Date().toISOString(), notes:jobNotes[id]||''});
  persistTracker();
  updateTrackerCount();
  showToast(`Added to ${KANBAN_STAGES.find(s=>s.key===stage)?.label||stage} in tracker.`, 2400, 'success');
}

function updateTrackerCount() {
  const n = Object.values(trackerApps).flat().length;
  document.getElementById('tracker-count').textContent = `(${n})`;
}

function renderSaved() {
  const el  = document.getElementById('saved-list');
