  set('s-name',cfg.name); set('s-email',cfg.email); set('s-phone',cfg.phone); set('s-loc',cfg.location);
  set('s-li',cfg.linkedin); set('s-portfolio',cfg.portfolio); set('s-resume',cfg.resume);
  set('s-groq',cfg.groqKey); set('s-tone',cfg.tone); set('s-len',cfg.length); set('s-model',cfg.model);
  set('s-indeed',cfg.indeedId); set('s-zip',cfg.zipKey); set('s-adz-id',cfg.adzunaId);
  set('s-adz-key',cfg.adzunaKey); set('s-usajobs-key',cfg.usajobsKey); set('s-usajobs-email',cfg.usajobsEmail);
  set('s-yoe',cfg.yoe); set('s-target-sal',cfg.targetSal);
  set('s-def-loc',cfg.defLoc); set('s-def-arr',cfg.defArr); set('s-def-type',cfg.defType); set('s-alerts',cfg.alerts);
  if (cfg.defLoc && !document.getElementById('loc').value) document.getElementById('loc').value=cfg.defLoc;
  updateProfileCompleteness(cfg);
}

function loadSkillsUI() {
  const cfg = loadSettings();
  userSkills = cfg.skills||[];
  const container = document.getElementById('skills-container');
  container.querySelectorAll('.skill-input-tag').forEach(t=>t.remove());
  userSkills.forEach(s => addSkillTag(s, false));
}

function addSkillTag(skill, persist) {
  if (!skill || userSkills.includes(skill)) return;
  if (persist) userSkills.push(skill);
  const container = document.getElementById('skills-container');
  const tag = document.createElement('div');
  tag.className = 'skill-input-tag';
  tag.innerHTML = `${escHtml(skill)}<button type="button" onclick="removeSkillTag(this,'${escHtml(skill)}')" title="Remove ${escHtml(skill)}">×</button>`;
  container.insertBefore(tag, document.getElementById('skill-input'));
}

function removeSkillTag(btn, skill) {
  btn.parentElement.remove();
  userSkills = userSkills.filter(s=>s!==skill);
}

function handleSkillInput(e) {
  if (e.key==='Enter' || e.key===',') {
    e.preventDefault();
    const skill = e.target.value.replace(',','').trim();
    if (skill) { addSkillTag(skill, true); e.target.value=''; }
  } else if (e.key==='Backspace' && !e.target.value) {
    const tags = document.getElementById('skills-container').querySelectorAll('.skill-input-tag');
    if (tags.length) {
      const last = tags[tags.length-1];
      const s = last.textContent.slice(0,-1).trim();
      userSkills = userSkills.filter(x=>x!==s);
      last.remove();
    }
  }
}

function handleSkillInputChange(e) {
  const val = e.target.value;
  if (val.endsWith(',')) {
    const skill = val.slice(0,-1).trim();
    if (skill) { addSkillTag(skill, true); e.target.value=''; }
  }
}

function updateProfileCompleteness(cfg) {
  const fields = ['name','email','phone','resume','location','linkedin'];
  const filled = fields.filter(f=>cfg[f]&&String(cfg[f]).trim()).length;
  const skillBonus = userSkills.length>0 ? 1 : 0;
  const score = Math.round((filled+skillBonus)/(fields.length+1)*100);
  const card = document.getElementById('profile-completeness');
  if (card) {
    card.style.display='';
    const bar = document.getElementById('profile-bar');
    bar.style.width  = score+'%';
    bar.style.background = score>=80?'var(--green)':score>=50?'var(--amber)':'var(--red)';
    document.getElementById('profile-bar-label').textContent = `${score}% complete${score<100?' — complete your profile to improve AI cover letter quality':''}`;
  }
}

function saveSettings() {
  const get = id => { const el=document.getElementById(id); return el?el.value.trim():''; };
  const cfg = {
    name:get('s-name'), email:get('s-email'), phone:get('s-phone'), location:get('s-loc'),
    linkedin:get('s-li'), portfolio:get('s-portfolio'), resume:get('s-resume'),
    groqKey:get('s-groq'), tone:get('s-tone'), length:get('s-len'), model:get('s-model'),
    indeedId:get('s-indeed'), zipKey:get('s-zip'), adzunaId:get('s-adz-id'),
    adzunaKey:get('s-adz-key'), usajobsKey:get('s-usajobs-key'), usajobsEmail:get('s-usajobs-email'),
    yoe:get('s-yoe'), targetSal:get('s-target-sal'),
    defLoc:get('s-def-loc'), defArr:get('s-def-arr'), defType:get('s-def-type'), alerts:get('s-alerts'),
    skills: userSkills,
    savedAt: new Date().toISOString(),
  };
  persistSettingsObj(cfg);
  showToast('Settings saved.', 2400, 'success');
  setStatus('Profile and settings saved successfully.');
  updateApiHealth(cfg);
  updateProfileCompleteness(cfg);
}

function clearSettings() {
  if (!confirm('Clear all saved settings and profile? This cannot be undone.')) return;
  localStorage.removeItem(STORAGE_KEY_SETTINGS);
  userSkills=[];
  loadSettingsUI(); loadSkillsUI();
  showToast('Settings cleared.', 2400);
}

function confirmNukeData() {
  if (!confirm('Delete ALL local data including saved jobs, tracker, settings, and metrics?\n\nThis action cannot be undone.')) return;
  [STORAGE_KEY_SAVED,STORAGE_KEY_SETTINGS,STORAGE_KEY_METRICS,STORAGE_KEY_TRACKER,STORAGE_KEY_NOTES].forEach(k=>localStorage.removeItem(k));
  savedJobs=[]; trackerApps={}; appliedCount=0; userSkills=[]; jobNotes={};
  updateSavedCount(); updateTrackerCount();
  showToast('All local data cleared.', 3000);
}

function exportData() {
  const data = {
    exported: new Date().toISOString(),
    version: '3.0',
    savedJobs, trackerApps, jobNotes,
    settings: {...loadSettings(), groqKey:undefined, adzunaKey:undefined, zipKey:undefined},
    metrics: {applied:appliedCount, saved:savedJobs.length},
  };
  const blob = new Blob([JSON.stringify(data,null,2)], {type:'application/json'});
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href = url;
  a.download = `jobnexus_export_${new Date().toISOString().slice(0,10)}.json`;
  a.click();
  URL.revokeObjectURL(url);
  showToast('Data exported as jobnexus_export_*.json', 2800, 'success');
}

function importData() {
  const input = document.createElement('input');
  input.type='file'; input.accept='.json';
  input.onchange = e => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = ev => {
      try {
        const data = JSON.parse(ev.target.result);
        if (data.savedJobs)   { savedJobs=data.savedJobs; persistSaved(); }
        if (data.trackerApps) { trackerApps=data.trackerApps; persistTracker(); }
        if (data.settings)    { persistSettingsObj(data.settings); }
        if (data.jobNotes)    { jobNotes=data.jobNotes; persistNotes(); }
        updateSavedCount(); updateTrackerCount();
        showToast('Data imported successfully.', 3000, 'success');
      } catch {
        showToast('Import failed — invalid JSON file.', 4000, 'error');
      }
    };
    reader.readAsText(file);
  };
  input.click();
}

function updateApiHealth(cfg) {
  const hasKeys = !!(cfg.adzunaId&&cfg.adzunaKey) || !!cfg.indeedId || !!cfg.zipKey || !!(cfg.usajobsKey&&cfg.usajobsEmail);
  const dot   = document.getElementById('api-health-dot');
  const label = document.getElementById('api-health-label');
  dot.className   = 'api-health-dot' + (hasKeys ? '' : ' warn');
  label.textContent = hasKeys ? 'Live API keys' : 'Demo mode';
}

document.addEventListener('keydown', e => {
  if (e.key==='Escape') {
    document.getElementById('cover-modal').style.display='none';
    document.getElementById('apply-modal').style.display='none';
    document.getElementById('add-app-modal').style.display='none';
    const kd = document.getElementById('kd-modal');
    if (kd) kd.remove();
  }
  if ((e.ctrlKey||e.metaKey) && e.key==='Enter') { e.preventDefault(); doSearch(); }
  if ((e.ctrlKey||e.metaKey) && e.key==='k')     { e.preventDefault(); document.getElementById('kw').focus(); document.getElementById('kw').select(); }
});

(function init() {
  buildSrcChips();
  buildCatChips();
  updateSavedCount();
  updateTrackerCount();
  updateApiHealth(loadSettings());
  loadSettingsUI();
  loadSkillsUI();

  if (!navigator.geolocation) {
    const btn = document.getElementById('geo-btn');
    if (btn) { btn.title='Geolocation not supported by this browser'; btn.style.opacity='.3'; btn.disabled=true; }
    const sta = document.getElementById('geo-status');
    if (sta)  sta.textContent='Geolocation unavailable in this browser.';
  }

  const cfg = loadSettings();
  if (cfg.defLoc) document.getElementById('loc').value=cfg.defLoc;
  if (cfg.defArr) document.getElementById('warr').value=cfg.defArr;
  if (cfg.defType) document.getElementById('jtype').value=cfg.defType;
})();
</script>
</body>
