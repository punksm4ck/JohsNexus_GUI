function haversineKm(lat1,lon1,lat2,lon2) {
  const R=6371, dL=(lat2-lat1)*Math.PI/180, dl=(lon2-lon1)*Math.PI/180;
  const a=Math.sin(dL/2)**2+Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dl/2)**2;
  return R*2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a));
}

function getJobCoords(job) {
  if (job.arrangement==='Remote') return null;
  for (const [city,coords] of Object.entries(CITY_COORDS)) {
    if (job.location.includes(city)) return coords;
  }
  const c = US_CITIES[Math.abs(job.id.split('').reduce((a,ch)=>a+ch.charCodeAt(0),0)) % US_CITIES.length];
  job.location = c + ', USA';
  return CITY_COORDS[c];
}

function tagLocalJobs() {
  if (!userCoords) return;
  allJobs.forEach(job => {
    const coords = getJobCoords(job);
    if (!coords) { job._distKm = null; return; }
    job._distKm = haversineKm(userCoords.lat, userCoords.lon, coords[0], coords[1]);
    job._distMi = job._distKm * 0.621371;
  });
}

function detectLocation() {
  const btn=document.getElementById('geo-btn'), sta=document.getElementById('geo-status');
  if (!navigator.geolocation) { sta.textContent='Geolocation not supported.'; sta.style.color='var(--red)'; return; }
  btn.textContent='⏳'; btn.disabled=true;
  sta.textContent='Detecting location…'; sta.style.color='var(--text2)';
  navigator.geolocation.getCurrentPosition(
    pos => {
      userCoords = {lat:pos.coords.latitude, lon:pos.coords.longitude};
      reverseGeocode(userCoords.lat, userCoords.lon, btn, sta);
    },
    err => {
      btn.textContent='⊕'; btn.disabled=false;
      const msgs = {1:'Location access denied.',2:'Position unavailable.',3:'Request timed out.'};
      sta.textContent = msgs[err.code]||'Location error.';
      sta.style.color = 'var(--red)';
    },
    {enableHighAccuracy:false, timeout:12000, maximumAge:120000}
  );
}

async function reverseGeocode(lat, lon, btn, sta) {
  try {
    const res = await fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lon}&format=json`, {headers:{'Accept-Language':'en'}});
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const data = await res.json();
    const addr = data.address || {};
    const city = addr.city||addr.town||addr.village||addr.county||'';
    const state = addr.state||'';
    userCityName = [city,state].filter(Boolean).join(', ');
    const locStr = userCityName + (addr.postcode ? ' ' + addr.postcode : '');
    document.getElementById('loc').value = locStr;
    sta.textContent = '✓ ' + locStr;
    sta.style.color = 'var(--green)';
    btn.textContent = '✓';
    btn.disabled = false;
    const pill = document.getElementById('local-pill');
    if (pill) pill.style.display = '';
    if (allJobs.length) { tagLocalJobs(); renderJobList(); }
  } catch(e) {
    sta.textContent = 'Reverse geocode failed.';
    sta.style.color = 'var(--red)';
    document.getElementById('loc').value = `${lat.toFixed(4)}, ${lon.toFixed(4)}`;
    btn.textContent = '⊕';
    btn.disabled = false;
  }
}

function getMatchScore(job, skills) {
  if (!skills || skills.length===0) return Math.floor(Math.random()*30+45);
  const jobText = (job.title+' '+job.description+' '+(job._skills||[]).join(' ')).toLowerCase();
  const matches = skills.filter(s => jobText.includes(s.toLowerCase()));
  const base = Math.min(100, Math.round((matches.length / Math.max(skills.length,1)) * 100));
  return Math.max(15, base + Math.floor(Math.random()*10-4));
}

