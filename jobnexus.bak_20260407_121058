function applyClientFilters() {
  const jtype         = document.getElementById('jtype').value;
  const wArr          = document.getElementById('warr').value;
  const explvl        = document.getElementById('explvl').value;
  const dpost         = parseInt(document.getElementById('dpost').value)||999;
  const salMin        = parseInt(document.getElementById('sal-min').value)||0;
  const salMax        = parseInt(document.getElementById('sal-max').value)||9999;
  const cosize        = document.getElementById('cosize').value;
  const industry      = document.getElementById('industry').value;
  const verifiedOnly  = document.getElementById('verified-toggle').checked;
  const excludeApplied= document.getElementById('exclude-applied-toggle').checked;
  const appliedIds    = new Set(Object.values(trackerApps).flat().map(a=>a.id));

  filteredJobs = allJobs.filter(j => {
    if (jtype && j.jobType!==jtype) return false;
    if (wArr && j.arrangement!==wArr) return false;
    if (explvl && j.expLevel!==explvl) return false;
    if (j.postedDays > dpost) return false;
    if (j.salaryLoK < salMin) return false;
    if (salMax < 9999 && j.salaryHiK > salMax) return false;
    if (cosize && j.coSize!==cosize) return false;
    if (industry && j.industry!==industry) return false;
    if (verifiedOnly && !j.verified) return false;
    if (excludeApplied && appliedIds.has(j.id)) return false;
    return true;
  });

  if (activeFilter==='Local') {
    tagLocalJobs();
    filteredJobs = filteredJobs.filter(j => j._distKm!=null && j._distKm<=80);
  } else if (activeFilter==='new') {
    filteredJobs = filteredJobs.filter(j => j.postedDays<=3);
  } else if (activeFilter!=='all') {
    filteredJobs = filteredJobs.filter(j => j.arrangement===activeFilter);
  }
}

function clearFilters() {
  ['jtype','warr','explvl','dpost','cosize','industry'].forEach(id => { document.getElementById(id).value=''; });
  ['sal-min','sal-max'].forEach(id => { document.getElementById(id).value=''; });
  document.getElementById('verified-toggle').checked=false;
  document.getElementById('exclude-applied-toggle').checked=true;
  activeFilter='all';
  document.querySelectorAll('.pill-filter').forEach(p => p.classList.toggle('active', p.dataset.f==='all'));
  if (allJobs.length) { applyClientFilters(); renderJobList(); }
  showToast('All filters cleared.', 2000);
}

function generateJobs(kw, loc, srcs) {
  const isRemote = /remote/i.test(loc);
  const wArr = document.getElementById('warr').value;
  const arr = isRemote ? ['Remote'] : wArr ? [wArr] : ['Remote','Remote','Hybrid','On-site'];
  const jobs = [];
  let count = 0;
  const roleSkills = getRoleSkills(kw);
  const titleTemplates = [
    kw, `Senior ${kw}`, `${kw} II`, `${kw} Lead`, `Staff ${kw}`,
    `Principal ${kw}`, `Junior ${kw}`, `${kw} Manager`, `Director of ${kw}`,
    `Associate ${kw}`, `${kw} Specialist`, `${kw} Consultant`,
    `VP of ${kw}`, `${kw} Analyst`, `Remote ${kw}`, `${kw} Architect`,
  ];

  srcs.forEach(src => {
    const n = Math.floor(Math.random()*10)+6;
    for (let i=0; i<n; i++) {
      const arrangement = arr[(count+i)%arr.length];
      const expIdx = (count+i) % EXP_LEVELS.length;
      const expLevel = EXP_LEVELS[expIdx];
      const baseK = expIdx<=1?45 : expIdx<=4?80 : expIdx<=6?130 : expIdx===7?180 : 220;
      const loK = baseK + Math.floor(Math.random()*25)-8;
      const hiK = loK + Math.floor(Math.random()*45)+20;
      const company = COMPANIES_POOL[(count+i*7)%COMPANIES_POOL.length];
      const postedDays = Math.floor(Math.random()*21)+1;
      const numSkills = Math.floor(Math.random()*5)+3;
      const shuffled = [...roleSkills].sort(()=>Math.random()-.5);
      const jobSkills = shuffled.slice(0, numSkills);
      const coData = COMPANY_DATA[company] || {
        size: CO_SIZES[(count+i)%CO_SIZES.length],
        industry: INDUSTRIES[(count+i)%INDUSTRIES.length],
        rating: (3.3 + Math.random() * 1.4).toFixed(1),
        glassdoor: `$${loK}K–$${hiK}K`,
        hq: loc,
        culture: 'Team-oriented, results-driven, collaborative and innovative',
      };
      jobs.push({
        id: `${src.id}-${count+i}-${Date.now()}`,
        title: titleTemplates[(count+i)%titleTemplates.length],
        company,
        location: arrangement==='Remote' ? 'Remote USA' : loc,
        arrangement,
        salaryLoK: Math.max(0, loK),
        salaryHiK: Math.max(loK+10, hiK),
        salary: `$${Math.max(0,loK)}K–$${Math.max(loK+10,hiK)}K/yr`,
        source: src.name,
        srcId: src.id,
        srcColor: src.color,
        srcAbbr: src.abbr,
        posted: postedDays===1?'Today' : postedDays<=2?`${postedDays}d ago` : `${postedDays}d ago`,
        postedDays,
        description: SAMPLE_DESCS[(count+i)%SAMPLE_DESCS.length],
        link: `https://www.google.com/search?q=${encodeURIComponent(titleTemplates[(count+i)%titleTemplates.length]+' '+company+' careers')}`,
        jobType: ['Full-time','Full-time','Full-time','Contract','Part-time'][(count+i)%5],
        expLevel,
        coSize: CO_SIZES[(count+i)%CO_SIZES.length],
        industry: coData.industry || INDUSTRIES[(count+i)%INDUSTRIES.length],
        verified: Math.random() > 0.28,
        _skills: jobSkills,
        _coData: coData,
        _isNew: postedDays<=3,
      });
      count++;
    }
  });

  const skillMatchEnabled = document.getElementById('skill-match-toggle').checked;
  jobs.forEach(j => { j._matchScore = getMatchScore(j, userSkills); });
  if (skillMatchEnabled && userSkills.length>0) {
    jobs.sort((a,b) => b._matchScore - a._matchScore);
  }
  return jobs;
}

function filterType(el) {
  activeFilter = el.dataset.f;
  document.querySelectorAll('.pill-filter').forEach(p => p.classList.toggle('active', p.dataset.f===activeFilter));
  if (activeFilter==='Local' && !userCoords) {
    showToast('Use the ⊕ button first to detect your location.', 3000);
    activeFilter='all';
    document.querySelectorAll('.pill-filter').forEach(p => p.classList.toggle('active', p.dataset.f==='all'));
  }
  applyClientFilters();
  if (!filteredJobs.length) showToast('No results for this filter — try broadening your search.', 3000);
  renderJobList();
}

function sortJobs() {
  const v = document.getElementById('sort-sel').value;
  if      (v==='alpha')     filteredJobs.sort((a,b)=>a.company.localeCompare(b.company));
  else if (v==='date')      filteredJobs.sort((a,b)=>a.postedDays-b.postedDays);
  else if (v==='salary_hi') filteredJobs.sort((a,b)=>b.salaryHiK-a.salaryHiK);
  else if (v==='salary_lo') filteredJobs.sort((a,b)=>a.salaryLoK-b.salaryLoK);
  else if (v==='match')     filteredJobs.sort((a,b)=>b._matchScore-a._matchScore);
  else filteredJobs.sort(()=>Math.random()-.5);
  renderJobList();
}

function arrPillClass(arr) {
  return arr==='Remote'?'pill-remote' : arr==='Hybrid'?'pill-hybrid' : 'pill-onsite';
}

function escHtml(str) {
  if (!str) return '';
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

