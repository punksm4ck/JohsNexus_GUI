async function generateCoverLetter(job) {
  const gen   = document.getElementById('cover-generating');
  const ta    = document.getElementById('cover-text');
  const badge = document.getElementById('groq-badge');
  const cfg   = loadSettings();
  const key   = cfg.groqKey||'';
  const tone  = document.getElementById('cover-tone-sel')?.value || cfg.tone || 'Professional and concise';
  ta.style.display='none'; gen.style.display='block'; badge.style.display='none';

  if (key && key.startsWith('gsk_')) {
    try {
      const name    = cfg.name||'Your Name';
      const resume  = cfg.resume||'an experienced professional with a proven track record of delivering results';
      const lenOpt  = cfg.length||'Standard (250–300 words)';
      const wordCnt = lenOpt.includes('Short')?'150–200 words' : lenOpt.includes('Detailed')?'350–400 words' : '250–300 words';
      const skills  = (cfg.skills||[]).join(', ');
      const model   = cfg.model||'llama-3.3-70b-versatile';
      const yoe     = cfg.yoe ? ` with ${cfg.yoe} of experience` : '';
      const prompt  = `Write a ${wordCnt} cover letter for a ${job.title} position at ${job.company} (${job.location}, ${job.arrangement}). Tone: ${tone}. Applicant background: ${resume}${yoe}.${skills ? ' Key skills: ' + skills + '.' : ''} The salary range is ${job.salary}. Open with "Dear Hiring Manager," and close with "Sincerely,\n${name}". Output only the letter body with no commentary, preamble, or markdown formatting.`;
      const res = await fetch('https://api.groq.com/openai/v1/chat/completions', {
        method:'POST',
        headers:{'Content-Type':'application/json','Authorization':`Bearer ${key}`},
        body:JSON.stringify({model, messages:[{role:'user',content:prompt}], max_tokens:850, temperature:0.72})
      });
      if (!res.ok) { const err=await res.json().catch(()=>({})); throw new Error(`Groq API ${res.status}: ${err?.error?.message||res.statusText}`); }
      const data = await res.json();
      const text = data.choices?.[0]?.message?.content||'';
      if (!text) throw new Error('Empty response from Groq API.');
      ta.value = text.trim();
      badge.style.display='inline-flex';
    } catch(err) {
      console.warn('Groq cover letter error:', err);
      showToast(`Groq error — using premium template. (${err.message.substring(0,55)})`, 4500);
      ta.value = buildFallbackLetter(job, cfg, tone);
    }
  } else {
    ta.value = buildFallbackLetter(job, cfg, tone);
  }
  gen.style.display='none';
  ta.style.display='';
}

function buildFallbackLetter(job, cfg, tone) {
  const name    = cfg.name||'Your Name';
  const res     = cfg.resume||'a results-driven professional with a strong background in delivering measurable impact';
  const skills  = (cfg.skills||[]).slice(0,3).join(', ');
  const t       = (tone||'').toLowerCase();
  const isWarm  = t.includes('warm');
  const isBold  = t.includes('confident');
  const opener  = isWarm ? 'I am genuinely excited to apply for' : isBold ? 'I am writing to express my strong candidacy for' : 'I am writing to apply for';
  return `Dear Hiring Manager,

${opener} the ${job.title} position at ${job.company}. With ${res}${skills?', including deep expertise in '+skills:''},  I am confident in my ability to make an immediate and meaningful contribution to your team.

${job.company}'s reputation for ${job._coData?.culture||'excellence, innovation, and impact'} aligns closely with the values I bring to every role. The ${job.arrangement} structure of this position particularly appeals to me — it reflects the kind of autonomous, results-oriented culture where I consistently perform at my highest level.

Throughout my career, I have distinguished myself through a combination of ${skills||'strategic thinking, collaborative problem-solving, and an unwavering focus on outcomes'}. I approach complex challenges with both analytical rigor and creative flexibility, and I am known for communicating clearly with stakeholders at every level of an organization.

What draws me most to this opportunity is the genuine potential to contribute to something meaningful. I believe the skills and experience I bring are a compelling match for what ${job.company} needs at this stage of growth.

I would welcome the opportunity to discuss how my background aligns with your team's goals. Thank you sincerely for your time and consideration.

Sincerely,
${name}`;
}

