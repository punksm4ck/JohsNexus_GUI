function moveApp(id, fromStage, toStage) {
  if (!toStage || toStage===fromStage) return;
  const apps = trackerApps[fromStage]||[];
  const idx  = apps.findIndex(a=>a.id===id);
  if (idx===-1) return;
  const app = apps.splice(idx,1)[0];
  if (!trackerApps[toStage]) trackerApps[toStage]=[];
  trackerApps[toStage].push(app);
  persistTracker();
  renderKanban();
  showToast(`Moved to ${KANBAN_STAGES.find(s=>s.key===toStage)?.label||toStage}.`, 2000, 'success');
  const m = document.getElementById('kd-modal');
  if (m) m.remove();
}

function saveKanbanNote(id, stage) {
  const ta  = document.getElementById('kd-notes');
  if (!ta) return;
  const app = (trackerApps[stage]||[]).find(a=>a.id===id);
  if (app) { app.notes = ta.value; persistTracker(); }
  showToast('Notes saved.', 2000, 'success');
}

function removeFromTracker(id) {
  Object.keys(trackerApps).forEach(s => { trackerApps[s]=(trackerApps[s]||[]).filter(a=>a.id!==id); });
  persistTracker();
  updateTrackerCount();
  renderKanban();
  showToast('Removed from tracker.', 2000);
  const m = document.getElementById('kd-modal');
  if (m) m.remove();
}

